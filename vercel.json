{
  "buildCommand": "echo 'Static SPA - no build needed'",
  "outputDirectory": ".",
  "devCommand": "npx http-server -p 3000",
  "routes": [
    {
      "src": "/shield\\.js",
      "dest": "/shield.js",
      "headers": {
        "Content-Type": "application/javascript",
        "Access-Control-Allow-Origin": "*",
        "Cache-Control": "public, max-age=3600"
      }
    },
    {
      "src": "/\\.well-known/(.*)",
      "dest": "/.well-known/$1"
    },
    {
      "src": "/shield$",
      "dest": "/shield.html"
    },
    {
      "src": "/agents$",
      "dest": "/agents.html"
    },
    {
      "src": "/submit$",
      "dest": "/submit.html"
    },
    {
      "src": "/review$",
      "dest": "/review.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
